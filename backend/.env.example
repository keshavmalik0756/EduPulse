# =========================================
# 🌐 APPLICATION
# =========================================
NODE_ENV=production
PORT=8080

# =========================================
# 🌍 FRONTEND (CORS SAFE)
# =========================================
FRONTEND_URL=https://edupulse-theta.vercel.app,http://localhost:5173

# =========================================
# 🔐 AUTH (JWT)
# =========================================
JWT_SECRET=REPLACE_WITH_64_CHAR_SECRET
JWT_EXPIRE=15m

REFRESH_TOKEN_SECRET=REPLACE_WITH_STRONG_REFRESH_SECRET
REFRESH_TOKEN_EXPIRE=7d

SESSION_SECRET=REPLACE_WITH_64_CHAR_SESSION_SECRET

# =========================================
# 🍪 COOKIE
# =========================================
COOKIE_EXPIRE=3

# =========================================
# 🔒 ENCRYPTION
# =========================================
ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_RANDOM_KEY

# =========================================
# 🗄️ DATABASE (MONGODB)
# =========================================
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.kdv5smn.mongodb.net/edupulse?retryWrites=true&w=majority

# =========================================
# ☁️ CLOUDINARY
# =========================================
CLOUDINARY_CLOUD_NAME=duceefwa0
CLOUDINARY_API_KEY=REPLACE_WITH_NEW_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_NEW_SECRET

# =========================================
# 💳 RAZORPAY
# =========================================
RAZORPAY_KEY_ID=REPLACE_WITH_NEW_KEY
RAZORPAY_KEY_SECRET=REPLACE_WITH_NEW_SECRET

# =========================================
# 📧 SMTP (EMAIL)
# =========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_MAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_SERVICE=

# =========================================
# ⚡ REDIS (UPSTASH - PRIMARY)
# =========================================
REDIS_URL=rediss://default:password@host:6379

# =========================================
# ⚡ REDIS REST (OPTIONAL - SERVERLESS)
# =========================================
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-token